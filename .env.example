# Shared SQLite database file. mise defaults this to an absolute project-local path.
DB_FILE_NAME=./data/comics.sqlite

# Crawlee/Playwright crawler skeleton.
CRAWLER_START_URLS=https://example.com
CRAWLER_MAX_REQUESTS=10
CRAWLER_HEADLESS=true
CRAWLER_CAPTURE_HTML=false
CRAWLEE_STORAGE_DIR=./storage/crawler

# Rouman5 opt-in network crawler. These commands are package-local and are not part of CI.
# Run `bun run --filter @comics/crawler rouman5:probe` before `rouman5:crawl`.
ROUMAN5_PROBE_MAX_REQUESTS=20
ROUMAN5_MAX_REQUESTS=10000
ROUMAN5_MAX_CONCURRENCY=1
ROUMAN5_SAME_DOMAIN_DELAY_SECS=2
ROUMAN5_PROBE_MAX_RUNTIME_SECS=300
ROUMAN5_MAX_RUNTIME_SECS=14400

# 18comic Hanman opt-in network crawler. Uses CloakBrowser-backed Crawlee.
# Run `bun run --filter @comics/crawler 18comic:probe` before `18comic:hanman`.
EIGHTEEN_COMIC_PROBE_MAX_REQUESTS=6
EIGHTEEN_COMIC_HANMAN_MAX_REQUESTS=3000
EIGHTEEN_COMIC_MAX_CONCURRENCY=1
EIGHTEEN_COMIC_SAME_DOMAIN_DELAY_SECS=3
EIGHTEEN_COMIC_PROBE_MAX_RUNTIME_SECS=300
EIGHTEEN_COMIC_HANMAN_MAX_RUNTIME_SECS=21600

# Production crawler runner. Commands stay package-local:
# `bun run --filter @comics/crawler production:probe` or `production:run`.
PRODUCTION_CRAWLER_SITES=rouman5,18comic
PRODUCTION_CRAWLER_LOCK_FILE=./data/crawler-production.lock
PRODUCTION_CRAWLER_LOG_DIR=./logs/crawler
PRODUCTION_CRAWLER_BACKUP_DIR=./data/backups
PRODUCTION_CRAWLER_KEEP_LOG_DAYS=14
PRODUCTION_CRAWLER_KEEP_STORAGE_DAYS=7
PRODUCTION_CRAWLER_KEEP_BACKUP_DAYS=30
ROUMAN5_MIN_PROBE_COMICS=1
ROUMAN5_MIN_FULL_COMICS=1
EIGHTEEN_COMIC_MIN_PROBE_COMICS=1
EIGHTEEN_COMIC_HANMAN_MIN_FULL_COMICS=1
PRODUCTION_CRAWLER_MAX_FAILED_REQUESTS=0
PRODUCTION_CRAWLER_MAX_MISSING_IMAGE_RATIO=0
PRODUCTION_CRAWLER_MAX_ZERO_CHAPTER_RATIO=0
PRODUCTION_CRAWLER_MAX_MISSING_VIEW_COUNT_RATIO=0.25
PRODUCTION_CRAWLER_MAX_UNKNOWN_STATUS_RATIO=0.75
# Optional JSON webhook. Alerts on failures/warnings; set ALERT_ON_SUCCESS=true to also notify success.
PRODUCTION_CRAWLER_ALERT_WEBHOOK_URL=
PRODUCTION_CRAWLER_ALERT_ON_SUCCESS=false
# Operational escape hatches for local debugging only.
PRODUCTION_CRAWLER_SKIP_MIGRATE=false
PRODUCTION_CRAWLER_SKIP_BROWSER_INSTALL=false
PRODUCTION_CRAWLER_SKIP_BACKUP=false

# Hono + Bun MCP HTTP API skeleton.
MCP_SERVER_NAME=comics-mcp-server
MCP_SERVER_VERSION=0.1.0
MCP_HOST=0.0.0.0
MCP_PORT=3000
# Comma-separated hostnames allowed by MCP host-header validation. Leave empty to disable.
MCP_ALLOWED_HOSTS=localhost,127.0.0.1
